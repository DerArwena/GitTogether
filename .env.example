# ─── Database ───────────────────────────────────────────
# PostgreSQL connection string
# For Docker: postgresql://gittogether:gittogether@localhost:5432/gittogether
# For hosted (Neon/PlanetScale): use their connection string
DATABASE_URL="postgresql://user:password@host:5432/database"

# ─── Auth ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SECRET="your-random-secret-here"

# Auth URL (must match your deployment URL)
AUTH_URL="http://localhost:3000"

# ─── OAuth Providers ───────────────────────────────────
# GitHub: https://github.com/settings/developers
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Email (Magic Link Auth) ──────────────────────────
# SMTP connection string for email magic links
# Examples:
# Resend:  smtp://resend:your-api-key@smtp.resend.com:587
# SendGrid: smtp://apikey:your-api-key@smtp.sendgrid.net:587
EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="noreply@gittogether.cc"

# ─── App Configuration ─────────────────────────────────
# Set to "true" to require invites for registration
APP_INVITE_ONLY="true"

# Optional: initial invite code for self-hosted setup
# APP_INVITE_CODE="welcome"

# App name (used in emails, page titles)
APP_NAME="GitTogether"

# Your public-facing URL (must match deployment)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
